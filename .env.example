# --- FastNetMon GUI Configuration ---

# JWT Secret for session tokens (Random 32-64 character string)
# Generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here

# Encryption Key for FastNetMon passwords (Exact 64 character hex string)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_64_char_hex_encryption_key_here

# The URL where your GUI is accessible (for CORS protection)
# In production, set this to your domain, e.g., http://fnm-gui.yourcompany.com
CORS_ORIGIN=http://localhost:8080

# Backend Port (Internal to docker, usually leave as 5000)
PORT=5000

# Initial admin account (created on first start only).
# If ADMIN_PASSWORD is not set, a random password is generated and
# printed once in the backend logs.
ADMIN_USERNAME=admin
#ADMIN_PASSWORD=choose_a_strong_password
